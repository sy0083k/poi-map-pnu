# 브이월드 WMTS 키를 입력하세요.
# 발급처: https://www.vworld.kr/dev/vkey.do
# Required
VWORLD_WMTS_KEY=YOUR_WMTS_KEY_HERE
ADMIN_ID=YOUR_ADMIN_ID_HERE
# 초기 비밀번호: 12345678
ADMIN_PW_HASH=$2b$12$iaY7OeourURbA9QW1t4TheiRqFcq1bAh83Dihl3zLaDVzg5OvhujC
SECRET_KEY=replace-with-long-random-secret

# App
APP_NAME="관심 필지 지도 (POI Map Geo)"
MAP_CENTER_LAT=36.7848
MAP_CENTER_LON=126.4500
MAP_DEFAULT_ZOOM=15

# Map / Cadastral
CADASTRAL_FGB_PATH=data/LSMD_CONT_LDREG_44210_202512.fgb
CADASTRAL_FGB_PNU_FIELD=PNU
CADASTRAL_FGB_CRS=EPSG:3857
CADASTRAL_MIN_RENDER_ZOOM=15

# Session / Access Control
SESSION_COOKIE_NAME=poi_map_pnu_session
SESSION_NAMESPACE=poi_map_pnu
ALLOWED_IPS=127.0.0.1/32,::1/128
SESSION_HTTPS_ONLY=false

# Login Rate Limit
LOGIN_MAX_ATTEMPTS=5
LOGIN_COOLDOWN_SECONDS=300

# Upload
MAX_UPLOAD_SIZE_MB=10
MAX_UPLOAD_ROWS=5000
UPLOAD_SHEET_NAME=목록

# Proxy Trust
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
